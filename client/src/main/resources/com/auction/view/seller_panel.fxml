<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.SellerController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
          alignment="CENTER_LEFT" spacing="12">
        <Button fx:id="backButton" text="Quay lai"
                onAction="#handleBack"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
        <Label text="Quan ly san pham va Phien dau gia"
               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Noi dung: 2 cot -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- COT TRAI: Danh sach san pham -->
        <VBox prefWidth="480" spacing="0"
              style="-fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">

            <!-- Toolbar -->
            <HBox style="-fx-background-color: white; -fx-padding: 10 16;
                         -fx-border-color: #eee; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT" spacing="8">
                <Label text="DANH SACH SAN PHAM"
                       style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="itemStatusLabel"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                <Button fx:id="refreshItemsButton" text="Lam moi"
                        onAction="#handleRefreshItems"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>

            <!-- Bang san pham -->
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colItemId"    text="ID"       prefWidth="80"/>
                    <TableColumn fx:id="colName"      text="Ten"      prefWidth="140"/>
                    <TableColumn fx:id="colType"      text="Loai"     prefWidth="90"/>
                    <TableColumn fx:id="colStartPrice" text="Gia KD"  prefWidth="90"/>
                    <TableColumn fx:id="colDesc"      text="Mo ta"    prefWidth="160"/>
                </columns>
            </TableView>

            <!-- Nut thao tac -->
            <HBox style="-fx-background-color: white; -fx-padding: 10 16;
                         -fx-border-color: #eee; -fx-border-width: 1 0 0 0;"
                  alignment="CENTER_RIGHT" spacing="8">
                <Button fx:id="deleteItemButton" text="Xoa san pham"
                        onAction="#handleDeleteItem"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-background-radius: 4; -fx-cursor: hand;"/>
                <Button fx:id="createAuctionFromItemButton" text="Chon de dau gia"
                        onAction="#handleSelectItemForAuction"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- COT PHAI: Form them/sua + tao phien + admin -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="12" style="-fx-padding: 16;">

                <!-- Form them / sua san pham -->
                <TitledPane text="Them / Sua san pham" expanded="true"
                            style="-fx-background-color: white; -fx-background-radius: 6;">
                    <VBox spacing="10" style="-fx-padding: 12;">

                        <HBox spacing="10">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Ten san pham *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                                <TextField fx:id="nameField" promptText="Nhap ten san pham"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Loai *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                                <ComboBox fx:id="typeCombo" prefWidth="130"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="4">
                            <Label text="Mo ta"
                                   style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                            <TextArea fx:id="descField" promptText="Mo ta san pham..."
                                      prefHeight="70" wrapText="true"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Gia khoi diem *"
                                   style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                            <TextField fx:id="startPriceField" promptText="VD: 500000"/>
                        </VBox>

                        <Label fx:id="formStatusLabel"
                               style="-fx-font-size: 12px; -fx-text-fill: #27ae60;"
                               visible="false" wrapText="true"/>

                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Button fx:id="clearFormButton" text="Huy / Xoa form"
                                    onAction="#handleClearForm"
                                    style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                           -fx-background-radius: 4; -fx-cursor: hand;"/>
                            <Button fx:id="saveItemButton" text="Them san pham"
                                    onAction="#handleSaveItem"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 4;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <!-- Form tao phien dau gia -->
                <TitledPane text="Tao phien dau gia" expanded="true"
                            style="-fx-background-color: white; -fx-background-radius: 6;">
                    <VBox spacing="10" style="-fx-padding: 12;">

                        <VBox spacing="4">
                            <Label text="San pham da chon (ID)"
                                   style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                            <TextField fx:id="selectedItemIdField"
                                       promptText="Chon san pham tu bang ben trai"
                                       editable="false"
                                       style="-fx-background-color: #ecf0f1;"/>
                        </VBox>

                        <HBox spacing="10">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Thoi gian bat dau"
                                       style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                                <TextField fx:id="startTimeField"
                                           promptText="yyyy-MM-ddTHH:mm:ss"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Thoi gian ket thuc"
                                       style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                                <TextField fx:id="endTimeField"
                                           promptText="yyyy-MM-ddTHH:mm:ss"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="4">
                            <Label text="Gia khoi diem phien dau gia"
                                   style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                            <TextField fx:id="auctionStartPriceField" promptText="VD: 500000"/>
                        </VBox>

                        <Label fx:id="auctionStatusLabel"
                               style="-fx-font-size: 12px;" wrapText="true"/>

                        <Button fx:id="createAuctionButton" text="Tao phien dau gia"
                                onAction="#handleCreateAuction"
                                maxWidth="Infinity"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-pref-height: 36px;
                                       -fx-background-radius: 4; -fx-cursor: hand;"/>
                    </VBox>
                </TitledPane>

                <!-- Admin Panel -->
                <TitledPane fx:id="adminPane" text="Admin - Quan ly nguoi dung"
                            expanded="false" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-background-radius: 6;">
                    <VBox spacing="10" style="-fx-padding: 12;">

                        <TableView fx:id="userTable" prefHeight="200">
                            <columns>
                                <TableColumn fx:id="colUserId"   text="ID"       prefWidth="80"/>
                                <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
                                <TableColumn fx:id="colRole"     text="Role"     prefWidth="80"/>
                                <TableColumn fx:id="colEmail"    text="Email"    prefWidth="160"/>
                            </columns>
                        </TableView>

                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Label fx:id="adminStatusLabel"
                                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="banUserButton" text="Ban user"
                                    onAction="#handleBanUser"
                                    style="-fx-background-color: #c0392b; -fx-text-fill: white;
                                           -fx-background-radius: 4; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
