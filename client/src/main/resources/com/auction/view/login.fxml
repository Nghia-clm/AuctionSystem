<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.LoginController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f0f4f8; -fx-padding: 24;">

    <!-- Tiêu đề -->
    <Label text="Hệ thống đấu giá trực tuyến"
           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="ĐĂNG NHẬP"
           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>

    <!-- Card -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                 -fx-effect: dropshadow(gaussian, #ccc, 8, 0, 0, 2);
                 -fx-padding: 20;" maxWidth="420" minWidth="360">

        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-tab-min-height: 32px;">

            <!-- ── Tab Đăng nhập ── -->
            <Tab text="Đăng nhập">
                <VBox spacing="12" style="-fx-padding: 16 0 4 0;">

                    <VBox spacing="3">
                        <Label text="Tên đăng nhập"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <TextField fx:id="loginUsernameField"
                                   promptText="Nhập tên đăng nhập"
                                   style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Mật khẩu"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <PasswordField fx:id="loginPasswordField"
                                       promptText="Nhập mật khẩu"
                                       style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <!-- Label lỗi: KHÔNG có managed="false" để hiện đúng -->
                    <Label fx:id="loginErrorLabel" wrapText="true"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;
                                  -fx-background-color: #fdecea; -fx-padding: 6 10;
                                  -fx-background-radius: 4;"
                           visible="false" managed="false"/>

                    <Button fx:id="loginButton" text="Đăng nhập"
                            onAction="#handleLogin"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-pref-height: 38px;
                                   -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 13px;"/>
                </VBox>
            </Tab>

            <!-- ── Tab Đăng ký ── -->
            <Tab text="Đăng ký">
                <VBox spacing="10" style="-fx-padding: 16 0 4 0;">

                    <VBox spacing="3">
                        <Label text="Tên đăng nhập"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <TextField fx:id="regUsernameField"
                                   promptText="Tối thiểu 3 ký tự"
                                   style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Mật khẩu"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <PasswordField fx:id="regPasswordField"
                                       promptText="Tối thiểu 6 ký tự"
                                       style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Email"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <TextField fx:id="regEmailField"
                                   promptText="example@email.com"
                                   style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Vai trò"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="regRoleCombo" maxWidth="Infinity"
                                  style="-fx-pref-height: 34px;"/>
                    </VBox>

                    <Label fx:id="regErrorLabel" wrapText="true"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;
                                  -fx-background-color: #fdecea; -fx-padding: 6 10;
                                  -fx-background-radius: 4;"
                           visible="false" managed="false"/>

                    <Label fx:id="regSuccessLabel" wrapText="true"
                           style="-fx-text-fill: #27ae60; -fx-font-size: 12px;
                                  -fx-background-color: #eafaf1; -fx-padding: 6 10;
                                  -fx-background-radius: 4;"
                           visible="false" managed="false"/>

                    <Button fx:id="registerButton" text="Đăng ký"
                            onAction="#handleRegister"
                            maxWidth="Infinity"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-pref-height: 38px;
                                   -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 13px;"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>

    <Label text="© 2026 Auction System – Nhóm sinh viên"
           style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>
</VBox>
