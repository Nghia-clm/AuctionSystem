<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.BidController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
          alignment="CENTER_LEFT" spacing="12">
        <Button fx:id="backButton" text="Quay lai"
                onAction="#handleBack"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
        <Label text="Phong dau gia"
               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="auctionIdLabel"
               style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
    </HBox>

    <!-- Noi dung chinh: 2 cot -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- COT TRAI: thong tin + dat gia + bieu do -->
        <VBox prefWidth="520" spacing="0"
              style="-fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">

            <!-- Thong tin san pham -->
            <VBox style="-fx-background-color: white; -fx-padding: 16;
                         -fx-border-color: #eee; -fx-border-width: 0 0 1 0;" spacing="8">
                <Label text="THONG TIN SAN PHAM"
                       style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                <Label fx:id="itemNameLabel"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
                       wrapText="true"/>
                <HBox spacing="16">
                    <VBox spacing="2">
                        <Label text="Loai" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
                        <Label fx:id="itemTypeLabel" style="-fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="Gia khoi diem" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
                        <Label fx:id="startingPriceLabel" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </HBox>
                <Label fx:id="itemDescLabel" wrapText="true"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Trang thai dau gia realtime -->
            <GridPane style="-fx-background-color: #f8f9fa; -fx-padding: 16;
                             -fx-border-color: #eee; -fx-border-width: 0 0 1 0;"
                      hgap="20" vgap="8">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="GIA HIEN TAI" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="currentPriceLabel" text="--"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="THOI GIAN CON LAI" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label fx:id="countdownLabel" text="--:--:--"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="NGUOI DAN DAU" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="currentLeaderLabel" text="--"
                       style="-fx-font-weight: bold; -fx-text-fill: #8e44ad;"
                       GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="TRANG THAI" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label fx:id="statusLabel" text="--"
                       style="-fx-font-weight: bold;"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="KET THUC LUC" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"
                       GridPane.columnSpan="2"/>
                <Label fx:id="endTimeLabel" text="--"
                       style="-fx-text-fill: #34495e;"
                       GridPane.columnIndex="0" GridPane.rowIndex="5"
                       GridPane.columnSpan="2"/>
            </GridPane>

            <!-- Form dat gia -->
            <VBox style="-fx-background-color: white; -fx-padding: 16;" spacing="10"
                  VBox.vgrow="NEVER">
                <Label text="DAT GIA"
                       style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="bidAmountField" HBox.hgrow="ALWAYS"
                               promptText="Nhap so tien muon dat"
                               style="-fx-pref-height: 38px; -fx-font-size: 14px;"/>
                    <Button fx:id="placeBidButton" text="Dat gia"
                            onAction="#handlePlaceBid"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-pref-height: 38px;
                                   -fx-background-radius: 4; -fx-cursor: hand;
                                   -fx-min-width: 110px;"/>
                </HBox>
                <Label fx:id="bidResultLabel" wrapText="true"
                       style="-fx-font-size: 12px;" visible="false"/>
            </VBox>

            <!-- Bieu do gia -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 10;
                         -fx-border-color: #eee; -fx-border-width: 1 0 0 0;">
                <Label text="BIEU DO GIA THEO THOI GIAN"
                       style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 11px;
                              -fx-padding: 0 0 6 0;"/>
                <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #fafafa;"/>
            </VBox>
        </VBox>

        <!-- COT PHAI: lich su bid -->
        <VBox prefWidth="380" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-padding: 16;" spacing="8">
            <Label text="LICH SU DAT GIA"
                   style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBidder" text="Nguoi dat" prefWidth="130"/>
                    <TableColumn fx:id="colAmount" text="So tien"   prefWidth="100"/>
                    <TableColumn fx:id="colTime"   text="Thoi gian" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>

    </HBox>
</VBox>
