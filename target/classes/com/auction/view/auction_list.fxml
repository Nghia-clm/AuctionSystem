<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.AuctionListController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <!-- Thanh header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
          alignment="CENTER_LEFT" spacing="12">
        <Label text="Auction System"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel"
               style="-fx-text-fill: #ecf0f1; -fx-font-size: 13px;"/>
        <Button fx:id="sellerPanelButton" text="Quan ly san pham"
                onAction="#handleSellerPanel"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
        <Button fx:id="logoutButton" text="Dang xuat"
                onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <!-- Thanh filter + refresh -->
    <HBox style="-fx-background-color: white; -fx-padding: 10 20;
                 -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="12">
        <Label text="Loc trang thai:"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <ComboBox fx:id="statusFilterCombo" prefWidth="130"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        <Button fx:id="refreshButton" text="Lam moi"
                onAction="#handleRefresh"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <!-- Bang danh sach phien -->
    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
               style="-fx-border-color: transparent;">
        <columns>
            <TableColumn fx:id="colId"           text="Ma phien"     prefWidth="220"/>
            <TableColumn fx:id="colItemName"     text="San pham"     prefWidth="200"/>
            <TableColumn fx:id="colCurrentPrice" text="Gia hien tai" prefWidth="120"/>
            <TableColumn fx:id="colStatus"       text="Trang thai"   prefWidth="100"/>
            <TableColumn fx:id="colEndTime"      text="Ket thuc luc" prefWidth="130"/>
            <TableColumn fx:id="colSeller"       text="Nguoi ban"    prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Thanh duoi: nut tham gia -->
    <HBox style="-fx-background-color: white; -fx-padding: 10 20;
                 -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;"
          alignment="CENTER_RIGHT" spacing="10">
        <Label text="Chon phien roi nhan:"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        <Button fx:id="joinButton" text="Tham gia dau gia"
                onAction="#handleJoin"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-pref-height: 34px;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

</VBox>
